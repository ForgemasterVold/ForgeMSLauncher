<Window x:Class="Launcher_2016.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="ForgeMS"
        Width="704"
        Height="677"
        WindowStyle="None"
        ResizeMode="NoResize"
        Background="Transparent"
        MouseLeftButtonDown="Window_MouseLeftButtonDown">

    <Grid>

        <!-- ForgeMS base artwork -->
        <Image Source="Imagens/forgeMS_launcher.png"
               Width="704"
               Height="677"
               Stretch="Fill"
               HorizontalAlignment="Left"
               VerticalAlignment="Top"/>

        <!-- Update/status area -->
        <Grid Margin="18,574,338,17">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <TextBlock x:Name="label2"
                       Grid.Row="0"
                       Text="Preparing the forge..."
                       Foreground="#D8C7A8"
                       FontSize="12"
                       Margin="8,5,8,2"/>

            <TextBlock x:Name="label7"
                       Grid.Row="1"
                       Text="Waiting..."
                       Foreground="#9C8B73"
                       FontSize="11"
                       Margin="8,0,8,4"/>

            <ProgressBar x:Name="pbStatus"
                         Grid.Row="2"
                         Height="14"
                         Margin="8,0,8,6"
                         Minimum="0"
                         Maximum="100"
                         Value="0"/>
        </Grid>

        <!-- Website -->
        <Button Margin="357,579,189,57"
                Background="Transparent"
                BorderThickness="0"
                Cursor="Hand">
            <TextBlock>
                <Hyperlink NavigateUri="https://your-website-here"
                           Click="Hyperlink_Click">
                    Website
                </Hyperlink>
            </TextBlock>
        </Button>

        <!-- Discord -->
        <Button Margin="357,621,189,16"
                Background="Transparent"
                BorderThickness="0"
                Cursor="Hand">
            <TextBlock>
                <Hyperlink NavigateUri="https://discord.gg/4YdxrNTntC"
                           Click="Hyperlink_Click">
                    Discord
                </Hyperlink>
            </TextBlock>
        </Button>

        <!-- Forge button -->
        <Button x:Name="button1"
                Click="button1_Click"
                Width="194"
                Height="82"
                Margin="0,0,17,14"
                HorizontalAlignment="Right"
                VerticalAlignment="Bottom"
                Background="Transparent"
                BorderThickness="0"
                Padding="0"
                Cursor="Hand">

            <Image Source="Imagens/forgeMS_play_base.png"
                   Stretch="Fill"/>
        </Button>

        <!-- Info button -->
        <Button Click="Button_Click_1"
                Width="22"
                Height="20"
                Margin="0,10,36,0"
                HorizontalAlignment="Right"
                VerticalAlignment="Top"
                Background="Transparent"
                BorderThickness="0"
                Cursor="Hand">
			<Image Source="Imagens/forgeMS_info.png"
       Stretch="Uniform"/>
        </Button>

        <!-- Close button -->
        <Button Click="Button_Click"
                Width="22"
                Height="20"
                Margin="0,10,10,0"
                HorizontalAlignment="Right"
                VerticalAlignment="Top"
                Background="Transparent"
                BorderThickness="0"
                Cursor="Hand">
			<Image Source="Imagens/forgeMS_close.png"
       Stretch="Uniform"/>
        </Button>

    </Grid>
</Window>