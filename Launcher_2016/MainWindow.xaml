<Window x:Class="Launcher_2016.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="ForgeMS"
        Width="704"
        Height="677"
        WindowStyle="None"
        ResizeMode="NoResize"
        AllowsTransparency="True"
        Background="Transparent"
        MouseLeftButtonDown="Window_MouseLeftButtonDown">

    <Grid>

        <!-- Background -->
        <Image Source="Imagens/forgeMS_launcher.png"
               Stretch="Fill"/>

        <!-- ========================= -->
        <!-- Update Status -->
        <!-- ========================= -->

        <Label x:Name="label2"
                   Content="Preparing the Forge..."
                   Foreground="#D8C7A8"
                   FontSize="12"
                   Margin="8,5,8,2"
                   Padding="0"/>

        <Label x:Name="label7"
                   Grid.Row="1"
                   Content="Waiting..."
                   Foreground="#9C8B73"
                   FontSize="11"
                   Margin="8,0,8,4"
                   Padding="0"/>

        <ProgressBar x:Name="pbStatus"
                     Width="300"
                     Height="14"
                     Margin="24,626,0,0"
                     HorizontalAlignment="Left"
                     VerticalAlignment="Top"
                     Minimum="0"
                     Maximum="100"
                     Value="0"/>

        <!-- ========================= -->
        <!-- Website -->
        <!-- ========================= -->

        <Label Margin="360,586,0,0"
           HorizontalAlignment="Left"
           VerticalAlignment="Top"
           Foreground="#D8C7A8">
            <Hyperlink x:Name="ws"
               Click="Hyperlink_Click">
                Website
            </Hyperlink>
        </Label>

        <!-- ========================= -->
        <!-- Discord -->
        <!-- ========================= -->


        <!-- Discord Button -->
        <Button x:Name="DiscordButton"
        Width="118"
        Height="34"
        HorizontalAlignment="Left"
        VerticalAlignment="Bottom"
        Margin="359,0,0,18"
        Background="Transparent"
        BorderThickness="0"
        Padding="0"
        Cursor="Hand"
        Focusable="False"
        Click="DiscordButton_Click">

            <Button.Template>
                <ControlTemplate TargetType="Button">
                    <Border Background="Transparent"
                    BorderThickness="0">
                        <ContentPresenter HorizontalAlignment="Stretch"
                                  VerticalAlignment="Stretch"/>
                    </Border>
                </ControlTemplate>
            </Button.Template>

            <Image x:Name="DiscordButtonImage"
           Source="Imagens/forgeMS_discord.png"
           Stretch="UniformToFill"  Margin="-24,-40,-14,2"/>
        </Button>

        <!-- ========================= -->
        <!-- Forge Button -->
        <!-- ========================= -->

        <!-- Forge Button -->
        <Button x:Name="button1"
        Width="210"
        Height="78"
        HorizontalAlignment="Right"
        VerticalAlignment="Bottom"
        Margin="0,0,15,12"
        Click="button1_Click"
        Background="Transparent"
        BorderThickness="0"
        Padding="0"
        Cursor="Hand"
        Focusable="False"
        HorizontalContentAlignment="Stretch"
        VerticalContentAlignment="Stretch"
        MouseEnter="ForgeButton_MouseEnter"
        MouseLeave="ForgeButton_MouseLeave">

            <Button.Template>
                <ControlTemplate TargetType="Button">
                    <Border Background="Transparent"
                    BorderThickness="0"
                    Padding="0">
                        <ContentPresenter
                    HorizontalAlignment="Stretch"
                    VerticalAlignment="Stretch"
                    RecognizesAccessKey="False"/>
                    </Border>
                </ControlTemplate>
            </Button.Template>

            <Image x:Name="ForgeButtonImage"
           Source="Imagens/forgeMS_play_base.png"
           Margin="15,-52,8,-35"
           Stretch="Fill">

                <Image.Effect>
                    <DropShadowEffect x:Name="ForgeButtonGlow"
                              Color="#FF6A00"
                              BlurRadius="0"
                              ShadowDepth="0"
                              Opacity="0"/>
                </Image.Effect>
            </Image>
        </Button>

        <!-- ========================= -->
        <!-- Info Button -->
        <!-- ========================= -->

        <Button Width="22"
                Height="22"
                HorizontalAlignment="Right"
                VerticalAlignment="Top"
                Margin="0,10,42,0"
                Background="Transparent"
                BorderThickness="0"
                Click="Button_Click_1">

            <Image Source="Imagens/forgeMS_info.png"/>

        </Button>

        <!-- ========================= -->
        <!-- Close Button -->
        <!-- ========================= -->

        <Button Width="22"
                Height="22"
                HorizontalAlignment="Right"
                VerticalAlignment="Top"
                Margin="0,10,12,0"
                Background="Transparent"
                BorderThickness="0"
                Click="Button_Click">

            <Image Source="Imagens/forgeMS_close.png"/>

        </Button>
        <!-- Compatibility controls required by the existing launcher backend -->
        <Label x:Name="label4"
       Visibility="Collapsed"/>

        <Label x:Name="label5"
       Visibility="Collapsed"/>

        <Label x:Name="label6"
       Visibility="Collapsed"/>

    </Grid>

</Window>